{
  "name": "wa-cli-mcp",
  "version": "1.0.0",
  "description": "WhatsApp CLI and MCP server powered by Baileys. Send/receive messages, media, reactions, and more from your terminal or Claude Code.",
  "type": "module",
  "bin": {
    "wa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp-server.ts",
    "test": "vitest run tests/unit tests/functional",
    "test:unit": "vitest run tests/unit",
    "test:functional": "vitest run tests/functional",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "cli",
    "mcp",
    "claude-code",
    "messaging"
  ],
  "license": "MIT",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "baileys": "7.0.0-rc.9",
    "commander": "^14.0.3",
    "mime-types": "^3.0.2",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
